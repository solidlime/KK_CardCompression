<Window x:Class="KK_CardCompression.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KKCC - Koikatsu Card Compression"
        Width="1080" Height="720" MinWidth="820" MinHeight="560"
        Icon="Assets/app-icon.png"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragEnter"
        Background="#F4F6FB"
        FontFamily="Yu Gothic UI">

    <Window.Resources>
        <SolidColorBrush x:Key="BgWindow" Color="#F4F6FB"/>
        <SolidColorBrush x:Key="BgPanel" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgHeader" Color="#F8FAFF"/>
        <SolidColorBrush x:Key="BgHover" Color="#EEF3FF"/>
        <SolidColorBrush x:Key="BgSelect" Color="#DFE9FF"/>
        <SolidColorBrush x:Key="TextMain" Color="#1D2738"/>
        <SolidColorBrush x:Key="TextSub" Color="#4A5B78"/>
        <SolidColorBrush x:Key="TextMuted" Color="#7283A0"/>
        <SolidColorBrush x:Key="BorderSoft" Color="#DCE4F2"/>
        <SolidColorBrush x:Key="Accent" Color="#2E77FF"/>
        <SolidColorBrush x:Key="AccentSoft" Color="#7CA8FF"/>

        <LinearGradientBrush x:Key="PrimaryButtonBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2E77FF" Offset="0"/>
            <GradientStop Color="#5F92FF" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="{StaticResource BgPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgSelect}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="{StaticResource PrimaryButtonBg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{StaticResource BgHeader}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSub}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="4,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="RowBd" Background="Transparent" CornerRadius="6" Margin="2,1" MinHeight="38">
                            <GridViewRowPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowBd" Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBd" Property="Background" Value="{StaticResource BgSelect}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InlineProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Background" Value="#E8EEFA"/>
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="ToggleSwitch" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="11" Background="#C8D4E8"/>
                            <Border x:Name="Thumb" Width="16" Height="16" CornerRadius="8"
                                    Background="White" HorizontalAlignment="Left"
                                    Margin="3,0,0,0" VerticalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="3" Opacity="0.25" Direction="270"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource Accent}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="66"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="12" Padding="18,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="9" Background="Transparent" Margin="0,0,10,0" ClipToBounds="True">
                        <Image Source="Assets/app-icon.png" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="KKCC" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
                        <TextBlock Text="Koikatsu Card Compression" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="TxtDropHint" Text="ファイルまたはフォルダをドロップ" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextMuted}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="プレビュー" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextMuted}" Margin="0,0,6,0"/>
                    <ToggleButton x:Name="TglPreviewEnabled" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="True" ToolTip="マウスオーバープレビュー ON/OFF"
                                  Checked="TglPreviewEnabled_Changed"
                                  Unchecked="TglPreviewEnabled_Changed"/>
                    <TextBlock Text="低CPU優先度" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextMuted}" Margin="12,0,6,0"/>
                    <ToggleButton x:Name="TglLowCpu" Style="{StaticResource ToggleSwitch}"
                                  IsChecked="False" ToolTip="処理中のCPU優先度を下げる"
                                  Checked="TglLowCpu_Changed"
                                  Unchecked="TglLowCpu_Changed"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="260"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*" MinWidth="280"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="12" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="入力ファイル" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextSub}"/>
                        <TextBlock x:Name="TxtInputCount" DockPanel.Dock="Right" Foreground="{StaticResource TextMuted}"/>
                    </DockPanel>
                    <ListView Grid.Row="1" x:Name="LvInput"
                              MouseDoubleClick="LvInput_DoubleClick"
                              PreviewMouseLeftButtonDown="Lv_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="Lv_PreviewMouseMove"
                              PreviewKeyDown="LvInput_PreviewKeyDown"
                              MouseMove="LvInput_MouseMove"
                              MouseLeave="LvInput_MouseLeave"
                              Loaded="LvInput_Loaded"
                              SelectionMode="Extended">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ファイル名" Width="190" DisplayMemberBinding="{Binding FileName}"/>
                                <GridViewColumn Header="フォルダ" Width="220" DisplayMemberBinding="{Binding FolderPath}"/>
                                <GridViewColumn Header="サイズ" Width="90" DisplayMemberBinding="{Binding SizeFormatted}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent" Cursor="SizeWE"/>

            <Border Grid.Column="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="12" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,8">
                        <TextBlock Text="出力ファイル" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextSub}"/>
                        <TextBlock x:Name="TxtOutputCount" DockPanel.Dock="Right" Foreground="{StaticResource TextMuted}"/>
                    </DockPanel>
                    <ListView Grid.Row="1" x:Name="LvOutput"
                              MouseDoubleClick="LvOutput_DoubleClick"
                              PreviewMouseLeftButtonDown="Lv_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="Lv_PreviewMouseMove"
                              MouseMove="LvOutput_MouseMove"
                              MouseLeave="LvOutput_MouseLeave"
                              Loaded="LvOutput_Loaded"
                              SelectionMode="Extended">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ファイル名" Width="165" DisplayMemberBinding="{Binding FileName}"/>
                                <GridViewColumn Header="フォルダ" Width="150" DisplayMemberBinding="{Binding FolderPath}"/>
                                <GridViewColumn Header="サイズ / 進捗" Width="130">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <TextBlock Grid.Row="0" Text="{Binding SizeFormatted}"
                                                           Foreground="{StaticResource TextMain}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <ProgressBar Grid.Row="1"
                                                             MinWidth="0"
                                                             HorizontalAlignment="Stretch"
                                                             Style="{StaticResource InlineProgress}"
                                                             Value="{Binding ProgressPercent}"
                                                             Margin="0,4,0,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="圧縮率" Width="80" DisplayMemberBinding="{Binding CompressionRatioText}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="0,10,0,0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="12" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="BtnCompress" Content="圧縮" Width="80" Margin="0,0,8,0" Style="{StaticResource PrimaryButton}" Click="BtnCompress_Click"/>
                    <Button x:Name="BtnDecompress" Content="解凍" Width="80" Margin="0,0,8,0" Style="{StaticResource ActionButton}" Click="BtnDecompress_Click"/>
                    <Button x:Name="BtnCancel" Content="中止" Width="80" Margin="0,0,8,0" Style="{StaticResource ActionButton}" Click="BtnCancel_Click" IsEnabled="False"/>
                    <Button x:Name="BtnClear" Content="クリア" Width="80" Margin="0,0,0,0" Style="{StaticResource ActionButton}" Click="BtnClear_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BtnSelectOutput" Content="出力先設定" Width="110" Margin="0,0,10,0" Style="{StaticResource ActionButton}" Click="BtnSelectOutput_Click"/>
                    <TextBlock x:Name="TxtOutputPath" Text="出力先: 未選択" VerticalAlignment="Center" MaxWidth="320" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextMuted}"/>
                </StackPanel>

                <Border Grid.Row="1" Grid.ColumnSpan="3" Height="1" Margin="0,8,0,0"
                        Background="{StaticResource BorderSoft}"/>

            </Grid>
        </Border>

        <Border Grid.Row="3" Margin="0,10,0,0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderSoft}" BorderThickness="1" CornerRadius="12" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <ProgressBar x:Name="ProgressBar" Style="{StaticResource InlineProgress}" Height="8" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtStatus" Text="待機中" Foreground="{StaticResource TextSub}"/>
                </StackPanel>

                <TextBlock Grid.Column="1" x:Name="TxtStats" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" Margin="16,0,0,0"/>
            </Grid>
        </Border>

        <Popup x:Name="PreviewPopup" Placement="Mouse" StaysOpen="True"
               AllowsTransparency="True" PopupAnimation="Fade">
            <Border Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderSoft}"
                    BorderThickness="1" CornerRadius="10" Padding="10">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="12" Opacity="0.15" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <Border Width="200" Height="200" Background="{StaticResource BgWindow}"
                            CornerRadius="6" ClipToBounds="True">
                        <Image x:Name="ImgPreview" Stretch="Uniform"/>
                    </Border>
                    <TextBlock x:Name="TxtPreviewName" MaxWidth="200" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMain}" TextTrimming="CharacterEllipsis"
                               Margin="0,6,0,2"/>
                    <TextBlock x:Name="TxtPreviewSize" FontSize="10"
                               Foreground="{StaticResource TextMuted}"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
