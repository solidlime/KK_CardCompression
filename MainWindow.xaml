<Window x:Class="KK_Archive.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KK Archive - コイカツ圧縮・解凍ツール"
        Width="800" Height="600"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragEnter"
        Background="#F5F5F5">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="KK Archive" FontSize="24" FontWeight="Bold" Foreground="#2C3E50"/>
            <TextBlock Text=" - コイカツ圧縮・解凍ツール" FontSize="16" VerticalAlignment="Bottom" Margin="10,0,0,2" Foreground="#7F8C8D"/>
        </StackPanel>

        <!-- ドロップ領域 -->
        <Border Grid.Row="1" BorderBrush="#3498DB" BorderThickness="2" CornerRadius="10"
                Background="#ECF0F1" Margin="0,0,0,10">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="ファイルまたはフォルダをここにドロップ"
                           FontSize="16" HorizontalAlignment="Center" Margin="0,10,0,5" Foreground="#2C3E50"/>
                <TextBlock Text="対応形式: キャラカード(.png), コーデデータ(.png), シーンデータ(.png)"
                           FontSize="12" HorizontalAlignment="Center" Foreground="#7F8C8D"/>
            </StackPanel>
        </Border>

        <!-- 操作ボタン -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnAuto" Content="自動判定" Width="100" Margin="0,0,10,0" Click="BtnAuto_Click"/>
            <Button x:Name="BtnCompress" Content="圧縮" Width="100" Margin="0,0,10,0" Click="BtnCompress_Click"/>
            <Button x:Name="BtnDecompress" Content="解凍" Width="100" Margin="0,0,10,0" Click="BtnDecompress_Click"/>
            <Button x:Name="BtnSelectOutput" Content="出力先選択" Width="120" Click="BtnSelectOutput_Click"/>
            <TextBlock x:Name="TxtOutputPath" Text="出力先: 未選択" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#7F8C8D"/>
        </StackPanel>

        <!-- 進捗・結果表示 -->
        <Border Grid.Row="3" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Padding="10">
            <StackPanel>
                <ProgressBar x:Name="ProgressBar" Height="20" Minimum="0" Maximum="100" Value="0"/>
                <TextBlock x:Name="TxtStatus" Text="待機中..." Margin="0,5,0,0" Foreground="#2C3E50"/>
                <TextBlock x:Name="TxtStats" Text="" Margin="0,5,0,0" Foreground="#7F8C8D"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
