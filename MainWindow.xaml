<Window x:Class="KK_Archive.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:KK_Archive"
        Title="KK Archive - コイカツ圧縮・解凍ツール"
        Width="1000" Height="680" MinWidth="760" MinHeight="480"
        Icon="Assets/app.ico"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragEnter"
        Background="#0D0F1A">

    <Window.Resources>
        <!-- ===== Color palette ===== -->
        <SolidColorBrush x:Key="BgPrimary"   Color="#0D0F1A"/>
        <SolidColorBrush x:Key="BgCard"      Color="#141827"/>
        <SolidColorBrush x:Key="BgHover"     Color="#1E2336"/>
        <SolidColorBrush x:Key="BgSelected"  Color="#1B2B45"/>
        <SolidColorBrush x:Key="AccentTeal"  Color="#00D4C8"/>
        <SolidColorBrush x:Key="AccentBlue"  Color="#4A9EFF"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#E8EAF6"/>
        <SolidColorBrush x:Key="TextSecond"  Color="#7B82A8"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#4A5270"/>
        <SolidColorBrush x:Key="BorderColor" Color="#232840"/>

        <!-- ===== Button base style ===== -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"  Value="{StaticResource BgHover}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentTeal}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource BgSelected}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button -->
        <Style x:Key="BtnAccent" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#00D4C8" Offset="0"/>
                        <GradientStop Color="#4A9EFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#0D0F1A"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
        </Style>

        <!-- ===== ListView style ===== -->
        <Style TargetType="ListView">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="AlternationCount" Value="2"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="4,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderThickness="0" CornerRadius="4" Margin="2,1">
                            <GridViewRowPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                <Setter TargetName="bd" Property="Background" Value="#0A0C18"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BgSelected}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GridViewColumnHeader -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecond}"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="Padding"         Value="6,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ProgressBar style ===== -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"      Value="{StaticResource AccentTeal}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00D4C8" Offset="0"/>
                                        <GradientStop Color="#4A9EFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ComboBox style ===== -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Height"          Value="36"/>
            <Setter Property="Padding"         Value="10,0"/>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource BgCard}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Padding"    Value="10,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ========== HEADER ========== -->
        <Border Grid.Row="0" Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="6" Margin="0,0,10,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00D4C8" Offset="0"/>
                                <GradientStop Color="#4A9EFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="KK" FontWeight="Bold" FontSize="12" FontFamily="Segoe UI"
                                   Foreground="#0D0F1A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="KK Archive" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                    <TextBlock Text="コイカツ圧縮・解凍ツール" FontSize="12" Margin="10,0,0,0"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" FontFamily="Segoe UI"/>
                </StackPanel>

                <TextBlock Grid.Column="1" x:Name="TxtDropHint"
                           Text="📂  ファイル・フォルダをここにドロップ"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="13" Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"/>
            </Grid>
        </Border>

        <!-- ========== DUAL PANE AREA ========== -->
        <Grid Grid.Row="1" Margin="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="200"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANE -->
            <Border Grid.Column="0" Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="8,8,0,0"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentTeal}" Margin="0,0,6,0"/>
                            <TextBlock Text="入力ファイル一覧" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecond}" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TxtInputCount" Text="" Margin="8,0,0,0" FontSize="11"
                                       Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ListView Grid.Row="1" x:Name="LvInput"
                              MouseDoubleClick="LvInput_DoubleClick"
                              PreviewMouseLeftButtonDown="Lv_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="Lv_PreviewMouseMove"
                              SelectionMode="Extended">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ファイル名"   Width="180" DisplayMemberBinding="{Binding FileName}"/>
                                <GridViewColumn Header="フォルダパス" Width="220" DisplayMemberBinding="{Binding FolderPath}"/>
                                <GridViewColumn Header="サイズ"       Width="80"  DisplayMemberBinding="{Binding SizeFormatted}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- RIGHT PANE -->
            <Border Grid.Column="2" Background="{StaticResource BgCard}"
                    BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="36"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="8,8,0,0"
                            BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                            <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBlue}" Margin="0,0,6,0"/>
                            <TextBlock Text="出力ファイル一覧" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecond}" FontFamily="Segoe UI"/>
                            <TextBlock x:Name="TxtOutputCount" Text="" Margin="8,0,0,0" FontSize="11"
                                       Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ListView Grid.Row="1" x:Name="LvOutput"
                              MouseDoubleClick="LvOutput_DoubleClick"
                              PreviewMouseLeftButtonDown="Lv_PreviewMouseLeftButtonDown"
                              PreviewMouseMove="Lv_PreviewMouseMove"
                              SelectionMode="Extended">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="ファイル名"   Width="160" DisplayMemberBinding="{Binding FileName}"/>
                                <GridViewColumn Header="フォルダパス" Width="180" DisplayMemberBinding="{Binding FolderPath}"/>
                                <GridViewColumn Header="サイズ"       Width="80"  DisplayMemberBinding="{Binding SizeFormatted}"/>
                                <GridViewColumn Header="圧縮率"       Width="70"  DisplayMemberBinding="{Binding CompressionRatioText}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- ========== TOOLBAR ========== -->
        <Border Grid.Row="2" Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button x:Name="BtnAuto"       Content="✦ 自動判定" Width="110"
                            Style="{StaticResource BtnAccent}" Margin="0,0,8,0" Click="BtnAuto_Click"/>
                    <Button x:Name="BtnCompress"   Content="▲ 圧縮"    Width="90"
                            Style="{StaticResource BtnBase}"  Margin="0,0,8,0" Click="BtnCompress_Click"/>
                    <Button x:Name="BtnDecompress" Content="▼ 解凍"    Width="90"
                            Style="{StaticResource BtnBase}"  Margin="0,0,16,0" Click="BtnDecompress_Click"/>
                    <TextBlock Text="圧縮レベル" VerticalAlignment="Center" Margin="0,0,6,0"
                               FontSize="12" Foreground="{StaticResource TextSecond}" FontFamily="Segoe UI"/>
                    <ComboBox x:Name="CmbLevel" Width="120">
                        <ComboBoxItem Content="⚡ 速い (互換)" Tag="Fast"    IsSelected="True"/>
                        <ComboBoxItem Content="⚖ 標準"        Tag="Normal"/>
                        <ComboBoxItem Content="◆ 最大圧縮"    Tag="Maximum"/>
                    </ComboBox>
                    <Button x:Name="BtnClear" Content="✕ クリア" Width="80"
                            Style="{StaticResource BtnBase}" Margin="12,0,0,0" Click="BtnClear_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button x:Name="BtnSelectOutput" Content="📁 出力先選択" Width="120"
                            Style="{StaticResource BtnBase}" Margin="0,0,10,0" Click="BtnSelectOutput_Click"/>
                    <TextBlock x:Name="TxtOutputPath" Text="出力先: 未選択" VerticalAlignment="Center"
                               FontSize="12" Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"
                               MaxWidth="300" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== STATUS BAR ========== -->
        <Border Grid.Row="3" Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="0,1,0,0" Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Value="0" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtStatus" Text="待機中 — ファイルをドロップしてください"
                               FontSize="12" Foreground="{StaticResource TextSecond}" FontFamily="Segoe UI"/>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="TxtStats" Text=""
                           FontSize="11" Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"
                           VerticalAlignment="Center" TextAlignment="Right" Margin="16,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
