using ManagedLZMA;
using ManagedLZMA.LZMA;
using System;
using System.IO;

namespace KK_Archive.Services
{
    public static class CompressionService
    {
        // LZMA圧縮設定（7zの極致圧縮に近い設定）
        private static readonly CoderPropId[] _propIds = new[]
        {
            CoderPropId.DictionarySize,
            CoderPropId.PosStateBits,
            CoderPropId.LitContextBits,
            CoderPropId.LitPosBits,
            CoderPropId.Algorithm,
            CoderPropId.NumFastBytes,
            CoderPropId.MatchFinder,
            CoderPropId.EndMarker
        };

        private static readonly object[] _propValues = new object[]
        {
            1 << 23, // DictionarySize: 8MB
            2,        // PosStateBits
            3,        // LitContextBits
            0,        // LitPosBits
            2,        // Algorithm
            128,      // NumFastBytes
            "bt4",    // MatchFinder
            true      // EndMarker
        };

        /// <summary>
        /// ファイルが圧縮済みか判定（簡易版：LZMAヘッダーをチェック）
        /// </summary>
        public static bool IsCompressed(string filePath)
        {
            try
            {
                using var fs = File.OpenRead(filePath);
                byte[] header = new byte[5];
                int read = fs.Read(header, 0, 5);
                if (read < 5) return false;

                // LZMAヘッダーの簡易チェック（実際はもっと厳密に）
                // 参考実装に合わせて、圧縮ファイルの先頭バイトをチェック
                return header[0] == 0x5D; // LZMAプロパティの先頭バイト（仮）
            }
            catch
            {
                return false;
            }
        }

        /// <summary>
        /// ファイルをLZMA圧縮
        /// </summary>
        public static void CompressFile(string inputPath, string outputPath)
        {
            using var inputStream = File.OpenRead(inputPath);
            using var outputStream = File.Create(outputPath);

            var encoder = new LzmaEncoder();
            encoder.SetCoderProperties(_propIds, _propValues);
            encoder.WriteCoderProperties(outputStream);

            // 元ファイルサイズを書き込む（8バイト）
            long fileSize = inputStream.Length;
            for (int i = 0; i < 8; i++)
                outputStream.WriteByte((byte)(fileSize >> (8 * i)));

            encoder.Code(inputStream, outputStream, inputStream.Length, -1, null);
        }

        /// <summary>
        /// LZMA圧縮ファイルを解凍
        /// </summary>
        public static void DecompressFile(string inputPath, string outputPath)
        {
            using var inputStream = File.OpenRead(inputPath);
            using var outputStream = File.Create(outputPath);

            var decoder = new LzmaDecoder();
            byte[] properties = new byte[5];
            if (inputStream.Read(properties, 0, 5) != 5)
                throw new InvalidDataException("Invalid LZMA header");

            decoder.SetDecoderProperties(properties);

            // 元ファイルサイズを読み込む（8バイト）
            byte[] fileSizeBytes = new byte[8];
            if (inputStream.Read(fileSizeBytes, 0, 8) != 8)
                throw new InvalidDataException("Invalid file size info");

            long fileSize = BitConverter.ToInt64(fileSizeBytes, 0);
            decoder.Code(inputStream, outputStream, inputStream.Length - 13, fileSize, null);
        }
    }
}
